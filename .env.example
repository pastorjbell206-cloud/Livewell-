# Livewell environment variables
# Copy this file to .env.local for local development.
# In production, set these in Vercel: Project Settings -> Environment Variables.
# NEVER commit a real .env file with real secrets.

# --- Database ---------------------------------------------------------------
# Postgres connection string. For Neon/Vercel Postgres, append ?sslmode=require
# Example: postgres://user:password@ep-xxx.us-east-1.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=

# --- Auth / Sessions --------------------------------------------------------
# Random 32+ byte secret used to sign session cookies.
# Generate with: openssl rand -base64 48
# Rotating this value invalidates ALL existing sessions (users must log back in).
JWT_SECRET=

# Bcrypt hash of the admin password (not the password itself!).
# Generate with: node -e "import('bcryptjs').then(b => b.default.hash('your-password', 10).then(console.log))"
ADMIN_PASSWORD_HASH=

# --- Runtime ----------------------------------------------------------------
# Do NOT set NODE_ENV on Vercel. Vercel manages it automatically.
# For local dev, `pnpm run dev` sets it to "development" for you.

# --- Optional integrations (leave blank if unused) --------------------------
# AWS S3 for media uploads
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
AWS_S3_BUCKET=

# Stripe (if enabling payments)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
