# LiveWell environment variables
# Copy to .env (and configure on Vercel) for local/production use.
# Variables prefixed with VITE_ are inlined into the client bundle at BUILD time
# and must be configured BEFORE the Vercel build runs.

# --- Server (runtime) ---
NODE_ENV=production
DATABASE_URL=postgresql://user:password@host:5432/livewell
JWT_SECRET=replace-with-a-long-random-string
ADMIN_PASSWORD_HASH=replace-with-bcrypt-hash-of-admin-password

# --- Client (build-time, Vite) ---
# Base URL of your OAuth portal (no trailing slash). Required for admin login redirects.
VITE_OAUTH_PORTAL_URL=https://your-oauth-portal.example.com
# Application ID registered with the OAuth portal.
VITE_APP_ID=your-app-id
